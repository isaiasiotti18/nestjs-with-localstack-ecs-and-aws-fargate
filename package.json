{
  "name": "bun-nestjs-ecs",
  "version": "1.0.0",
  "description": "Bun + NestJS boilerplate with MikroORM, ready for ECS Fargate on LocalStack",
  "scripts": {
    "start": "bun run dist/main.js",
    "start:dev": "nest start --watch --exec 'bun run'",
    "start:debug": "nest start --debug --watch --exec 'bun run'",
    "build": "nest build",
    "start:prod": "bun run dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "migration:create": "bun run mikro-orm migration:create",
    "migration:up": "bun run mikro-orm migration:up",
    "migration:down": "bun run mikro-orm migration:down",
    "schema:update": "bun run mikro-orm schema:update --run"
  },
  "dependencies": {
    "@mikro-orm/cli": "^6.4.0",
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.6.0"
  },
  "mikro-orm": {
    "useTsNode": false,
    "configPaths": [
      "./dist/config/mikro-orm.config.js"
    ]
  }
}
